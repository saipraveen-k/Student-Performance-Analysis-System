<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studentanalysis.controller.AddStudentController"
      spacing="15" prefWidth="400" prefHeight="350" styleClass="root">
    <children>
        <Label text="Add New Student" styleClass="label header" />

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="100" prefWidth="100" />
                <ColumnConstraints minWidth="250" prefWidth="250" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="30" prefHeight="30" />
                <RowConstraints minHeight="30" prefHeight="30" />
                <RowConstraints minHeight="30" prefHeight="30" />
                <RowConstraints minHeight="30" prefHeight="30" />
            </rowConstraints>

            <Label text="Name:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <TextField fx:id="nameField" promptText="Enter student name" GridPane.columnIndex="1" GridPane.rowIndex="0" />

            <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <TextField fx:id="emailField" promptText="Enter email address" GridPane.columnIndex="1" GridPane.rowIndex="1" />

            <Label text="Phone:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="phoneField" promptText="Enter phone number" GridPane.columnIndex="1" GridPane.rowIndex="2" />

            <Label text="Enrollment Date:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <DatePicker fx:id="enrollmentDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        </GridPane>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Save" onAction="#handleSave" styleClass="button" />
            <Button text="Cancel" onAction="#handleCancel" />
        </HBox>

        <Label fx:id="messageLabel" text="" styleClass="label" />
    </children>
</VBox>
