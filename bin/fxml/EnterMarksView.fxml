<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.studentanalysis.controller.EnterMarksController"
      spacing="15" prefWidth="500" prefHeight="400" styleClass="root">
    <children>
        <Label text="Enter Marks" styleClass="label header" />

        <GridPane hgap="10" vgap="10">
            <columnConstraints>
                <ColumnConstraints minWidth="120" prefWidth="120" />
                <ColumnConstraints minWidth="200" prefWidth="200" />
                <ColumnConstraints minWidth="120" prefWidth="120" />
            </columnConstraints>
            <rowConstraints>
                <RowConstraints minHeight="30" prefHeight="30" />
                <RowConstraints minHeight="30" prefHeight="30" />
                <RowConstraints minHeight="30" prefHeight="30" />
                <RowConstraints minHeight="30" prefHeight="30" />
            </rowConstraints>

            <Label text="Student:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
            <ComboBox fx:id="studentComboBox" promptText="Select student" GridPane.columnIndex="1" GridPane.rowIndex="0" GridPane.columnSpan="2" />

            <Label text="Subject:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
            <ComboBox fx:id="subjectComboBox" promptText="Select subject" GridPane.columnIndex="1" GridPane.rowIndex="1" GridPane.columnSpan="2" />

            <Label text="Marks Obtained:" GridPane.columnIndex="0" GridPane.rowIndex="2" />
            <TextField fx:id="marksObtainedField" promptText="Enter marks obtained" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label text="Total Marks:" GridPane.columnIndex="2" GridPane.rowIndex="2" />
            <TextField fx:id="totalMarksField" promptText="Enter total marks" GridPane.columnIndex="3" GridPane.rowIndex="2" />

            <Label text="Exam Date:" GridPane.columnIndex="0" GridPane.rowIndex="3" />
            <DatePicker fx:id="examDatePicker" promptText="Select exam date" GridPane.columnIndex="1" GridPane.rowIndex="3" GridPane.columnSpan="2" />
        </GridPane>

        <HBox spacing="10" alignment="CENTER">
            <Button text="Save" onAction="#handleSave" styleClass="button" />
            <Button text="Cancel" onAction="#handleCancel" />
        </HBox>

        <Label fx:id="messageLabel" text="" styleClass="label" />
    </children>
</VBox>
